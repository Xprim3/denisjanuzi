# Where website request emails are delivered
CONTACT_EMAIL=denisjanuzi@gmail.com

# --- Recommended: Gmail (sends directly to your inbox) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste it below (16 characters, no spaces)
GMAIL_USER=denisjanuzi@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# --- Alternative: Resend ---
# Free test mode only sends to the email you signed up with on Resend.
# To send to denisjanuzi@gmail.com, verify denisjanuzi.com at resend.com/domains first.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=Website Form <form@denisjanuzi.com>
