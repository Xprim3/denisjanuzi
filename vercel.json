{
  "functions": {
    "api/webform.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/webform",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/webform.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/webform", "destination": "/webform.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
